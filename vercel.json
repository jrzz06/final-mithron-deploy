{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "mithron-flight-systems-kbkbkh.vercel.app" }],
      "destination": "https://final-mithron-deploy.vercel.app/:path*",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/admin/prune-logs",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/admin/archive-movements",
      "schedule": "0 4 1 * *"
    },
    {
      "path": "/api/payments/expire-pending",
      "schedule": "0 2 * * *"
    }
  ]
}
